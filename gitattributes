# Forzar TODO PHP a contarse como HTML (agresivo, asegura que aparezca "HTML")
*.php linguist-language=HTML

# Eliminar "Hack" del conteo (si no lo usas realmente)
*.hack linguist-detectable=false
*.hh   linguist-detectable=false

# Excluir dependencias y bundles del cálculo de lenguajes
vendor/**                  linguist-vendored
public/vendor/**           linguist-vendored
public/libs/**             linguist-vendored
node_modules/**            linguist-vendored
bower_components/**        linguist-vendored
*.min.js                   linguist-vendored
*.min.css                  linguist-vendored
public/**/*.min.js         linguist-vendored
public/**/*.min.css        linguist-vendored
public/dist/**             linguist-vendored
public/build/**            linguist-vendored
public/bundle/**           linguist-vendored

# Excluir assets estáticos para no distorsionar el porcentaje
assets/css/**              linguist-vendored
assets/img/**              linguist-vendored
public/images/**           linguist-vendored
public/img/**              linguist-vendored
*.png                      linguist-vendored
*.jpg                      linguist-vendored
*.jpeg                     linguist-vendored
*.gif                      linguist-vendored
*.svg                      linguist-vendored
*.webp                     linguist-vendored
*.ico                      linguist-vendored

# Documentación y configs fuera del conteo de lenguajes
*.md                       linguist-documentation
LICENSE*                   linguist-documentation
*.json                     linguist-vendored
*.yml                      linguist-vendored
*.yaml                     linguist-vendored
*.lock   
